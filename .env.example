APP_NAME=Laravel
APP_ENV=local
APP_KEY=
# デフォルトは安全側の false。ローカル開発でエラー詳細が必要なときだけ true に切り替える。
APP_DEBUG=false
APP_URL=http://localhost

# モバイル用 JSON API は /api/v1（Bearer Sanctum）。SwiftUI サンプルは ios/README.md を参照。
# Sanctum が先に web セッションを見ないよう config/sanctum.php の guard は空配列（トークンのみ）にしてある。
# 同一オリジンで Sanctum クッキー＋API を併用する場合は guard を ['web'] に戻すなど要調整。

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=cryptoapp
DB_USERNAME=cryptoapp_app
# 空欄のまま git にコミットされないよう `.env` は `.gitignore` に登録済み。
#   - ローカル: `openssl rand -hex 24` 相当のランダム値を割り当てる（DBロール作成時に合わせる）
#   - 本番:    ホスティング側のシークレット機構 (AWS SSM Parameter Store / GCP Secret Manager / Vault 等)
#             からプロセス環境変数として注入し、`.env` には書かない運用を推奨。
#             パスワードは最低 180 日ごとにローテーションする。
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
# 本番（APP_ENV=production）では未指定のままでも自動的に true として扱われる。
# ステージングで HTTP を利用する場合は明示的に false を指定する。
# SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# 本番でリバースプロキシ/LBの背後に置く場合はプロキシのIP/CIDR、または '*' を指定する。
# TRUSTED_PROXIES=*

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
